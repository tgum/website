-- greg
local attributes, items = extract_extra(content)
local lines = strease.split(items, "\n")
local output = "<ul "..attributes.." >"
for i, line in ipairs(lines) do
	if strease.trim(line) ~= "" then
		output = output .. "\n<li>" .. line .. "</li>"
	end
end
return output.."</ul>"
